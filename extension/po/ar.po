msgid "Background style"
msgstr "أسلوب الخلفيَّة"

#: resources/ui/dash.ui:156
msgid "The transparent/semi-transparent style for the dock background."
msgstr "أسلوب خلفيَّة المرسى الشفَّاف أو شبه الشفَّاف."

#: resources/ui/dash.ui:172 resources/ui/panel.ui:163
msgid "Disable in overview"
msgstr "عطِّل في النظرة العامَّة"

#: resources/ui/dash.ui:173
msgid "Disables the blur from Dhruva Dock when entering the overview."
msgstr ""

#: resources/ui/dash.ui:232 resources/ui/overview.ui:196
#: resources/ui/overview.ui:240 resources/ui/panel.ui:218
