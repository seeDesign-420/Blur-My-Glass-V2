msgid "Overlay"
msgstr ""

#: src/effects/effects.js:184
msgid "Darken"
msgstr ""

#: src/effects/effects.js:185
msgid "Lighten"
msgstr ""

#: src/effects/effects.js:186
msgid "Plus darker"
msgstr ""

#: src/effects/effects.js:187
msgid "Plus lighter"
msgstr ""

