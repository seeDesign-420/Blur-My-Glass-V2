msgid "Project page"
msgstr "Страница проекта"

#: resources/ui/menu.ui:10
msgid "Report a Bug"
msgstr "Сообщить об ошибке"

#: resources/ui/menu.ui:14
msgid "License"
msgstr "Лицензия"

#: resources/ui/menu.ui:18
msgid "Donate"
msgstr "Пожертвовать"

#: resources/ui/other.ui:5
msgid "Other"
msgstr "Прочее"

#: resources/ui/other.ui:10
msgid "Lockscreen blur"
msgstr "Размытие экрана блокировки"

#: resources/ui/other.ui:11
msgid "Enable dynamic blur on the lockscreen background."
msgstr ""

#: resources/ui/other.ui:21
msgid "The intensity of the lockscreen blur."
msgstr ""

#: resources/ui/other.ui:42
msgid "The brightness of the lockscreen blur effect."
msgstr ""

#: resources/ui/other.ui:63
msgid "Adds color richness while keeping lockscreen content readable."
msgstr ""

#: resources/ui/other.ui:85
msgid "Performance"
msgstr "Производительность"

#: resources/ui/other.ui:86
msgid "Various options to tweak the performance."
msgstr "Различные опции для настройки производительности."

#: resources/ui/other.ui:90
msgid "Hack level"
msgstr "Уровень взлома"

#: resources/ui/other.ui:91
msgid ""
"Changes the behaviour of the dynamic blur effect. The default value is "
"highly recommended.\n"
"The “No artifact” option will entirely disable clipped redraws in GNOME "
"shell, and will impact your computer performances significantly."
msgstr ""
"Изменяет поведение эффекта динамического размытия. Настоятельно "
"рекомендуется использовать значение по умолчанию.\n"
"Опция \"Без артефактов\" полностью отключит обрезанные перерисовки в "
"оболочке GNOME и существенно повлияет на производительность вашего "
"компьютера."

#: resources/ui/other.ui:105
msgid "Debug"
msgstr "Отладка"

#: resources/ui/other.ui:106
msgid ""
"Makes the extension verbose in logs, activate when you need to report an "
"issue."
msgstr ""
