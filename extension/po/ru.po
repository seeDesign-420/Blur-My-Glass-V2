#: resources/ui/overlays.ui:83
msgid "Refraction strength"
msgstr ""

#: resources/ui/applications.ui:85 resources/ui/dash.ui:110
#: resources/ui/overlays.ui:84
msgid "Strength of the liquid glass distortion."
msgstr ""

#: resources/ui/applications.ui:105 resources/ui/dash.ui:130
#: resources/ui/overlays.ui:104
msgid "Refraction radius"
msgstr ""

#: resources/ui/applications.ui:106 resources/ui/dash.ui:131
#: resources/ui/overlays.ui:105
msgid "Radius used by the liquid glass distortion."
msgstr ""

#: resources/ui/applications.ui:114 resources/ui/dash.ui:139
#: resources/ui/overlays.ui:113
msgid "Refraction inner rounding"
msgstr ""

#: resources/ui/applications.ui:115 resources/ui/dash.ui:140
#: resources/ui/overlays.ui:114
