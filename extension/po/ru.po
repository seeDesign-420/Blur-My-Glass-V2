msgid "Background style"
msgstr "Стиль фона"

#: resources/ui/dash.ui:156
msgid "The transparent/semi-transparent style for the dock background."
msgstr "Прозрачный/полупрозрачный стиль для фона панели приложений."

#: resources/ui/dash.ui:172 resources/ui/panel.ui:163
msgid "Disable in overview"
msgstr "Отключить в Обзоре"

#: resources/ui/dash.ui:173
msgid "Disables the blur from Dhruva Dock when entering the overview."
msgstr ""

#: resources/ui/dash.ui:232 resources/ui/overview.ui:196
#: resources/ui/overview.ui:240 resources/ui/panel.ui:218
msgid "Transparent"
msgstr "Прозрачный"

#: resources/ui/dash.ui:233 resources/ui/overview.ui:194
#: resources/ui/overview.ui:241 resources/ui/panel.ui:219
msgid "Light"
msgstr "Светлый"

#: resources/ui/dash.ui:234 resources/ui/overview.ui:195
#: resources/ui/overview.ui:242 resources/ui/panel.ui:220
msgid "Dark"
msgstr "Темный"

