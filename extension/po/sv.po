#: resources/ui/overview.ui:5
msgid "Overview"
msgstr "Översiktsläge"

#: resources/ui/overview.ui:10
msgid "Background blur"
msgstr "bakgrundsoskärpa"

#: resources/ui/overview.ui:11
msgid "Add blur to the overview background, using the wallpaper picture."
msgstr ""
"Lägg till oskärpa i översiktlägets bakgrund genom att använda "
"bakgrundsbilden."

#: resources/ui/overview.ui:63
msgid "Adds color richness while keeping overview content readable."
msgstr ""

#: resources/ui/overview.ui:83
msgid "Overview components style"
msgstr "Stil på översiktlägets komponent"

#: resources/ui/overview.ui:84
msgid ""
"The semi-transparent style for the dash, search entry/results, and "
"application folders."
msgstr ""
"Genomskicklighetens stil för dash, sökning, sökresultat och "
"applikationsmappar."

#: resources/ui/overview.ui:101
msgid "Application folder blur"
msgstr "Oskärpa för applikationsmappar"

#: resources/ui/overview.ui:102
msgid "Makes the background of application folder dialogs blurred."
msgstr "Gör bakgrunden i dialoger för applikationsmappar suddig."

#: resources/ui/overview.ui:154
msgid "Adds color richness while keeping the folder dialog readable."
msgstr ""

#: resources/ui/overview.ui:174
msgid "Application folder dialogs style"
msgstr "Stil för dialoger för applikationsmappar"

#: resources/ui/overview.ui:175
msgid "The semi-transparent style for the application folder dialogs."
msgstr "Halvtransparensens stil för dialoger för applikationsmappar."

#: resources/ui/overview.ui:193 resources/ui/overview.ui:239
msgid "Do not style"
msgstr "Styla inte"

#: resources/ui/panel.ui:5
msgid "Panel"
msgstr "Panel"

#: resources/ui/panel.ui:10
msgid "Panel blur"
msgstr "Paneloskärpa"

#: resources/ui/panel.ui:11
msgid "Blur the top panel with the current dynamic background material."
msgstr ""

#: resources/ui/panel.ui:63
msgid "Adds color richness while keeping the blur readable."
msgstr ""

#: resources/ui/panel.ui:109
msgid "Force light text"
msgstr "Tvinga ljus text"

#: resources/ui/panel.ui:110
msgid ""
"Use a light text for the panel, useful when using gnome-shell's light theme."
msgstr ""
"Använd en ljus text för panelen, användbart när du använder gnome-shell "
"ljusa tema."

#: resources/ui/panel.ui:125
msgid ""
"Override the background of the panel to use a transparent or semi-"
"transparent one.\n"
"Recommended unless you want to customize your GNOME theme."
msgstr ""
"Åsidosätt panelens bakgrund för att använda en transparent eller "
"halvtransparent sådan.\n"
"Rekommenderas om man inte vill anpassa GNOME-temat."

#: resources/ui/panel.ui:133
msgid "The transparent/semi-transparent style for the panel background."
msgstr "Transparensens/halvtransparensens stil för panelbakgrunden."

#: resources/ui/panel.ui:147
msgid "Disable when a window is near"
msgstr "Inaktivera när ett fönster är nära"

#: resources/ui/panel.ui:148
msgid "Disables the transparency of the panel when a window is near it."
msgstr "Inaktiverar genomskinligheten för panelen när ett fönster är nära den."

#: resources/ui/panel.ui:164
msgid "Disables the blur from the panel when entering the overview."
msgstr ""
"Inaktiverar oskärpa från panelen när man kommer in till översiktsläget."

#: resources/ui/panel.ui:180
msgid "Compatibility"
msgstr "Kompatibilitet"

#: resources/ui/panel.ui:181
msgid "Various options to provide compatibility with other extensions."
msgstr "Olika alternativ för kompatibilitet med andra tillägg."

#: resources/ui/panel.ui:186
msgid "Hidetopbar extension"
msgstr "Hidetopbar-tillägg"

#: resources/ui/panel.ui:187
msgid ""
"Does not disable the blur in overview when Hidetopbar controls panel "
"visibility."
msgstr ""

#: resources/ui/panel.ui:201
msgid "Blur original panel with Dash to Panel"
msgstr "Blurra originalpanelen med Dash to Panel"

#: resources/ui/panel.ui:202
msgid ""
"Enables the blurring of the original panel with Dash to Panel, if selected "
"in the extension's options."
msgstr ""
"Aktiverar blurrighet av originalpanelen med Dash to Panel, om det är valt i "
"tilläggets alternativ."

#: resources/ui/panel.ui:221
msgid "Contrasted"
msgstr "Kontrasterad"
