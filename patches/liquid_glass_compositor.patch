Subject: [PATCH] Shell.BlurEffect: add liquid glass refraction overlay
---
 src/shell-blur-effect.c | 119 +++++++++++++++++++++++++++++++++++++---
 src/shell-blur-effect.h |   4 ++
 2 files changed, 116 insertions(+), 7 deletions(-)

diff --git a/src/shell-blur-effect.c b/src/shell-blur-effect.c
--- a/src/shell-blur-effect.c
+++ b/src/shell-blur-effect.c
@@ -50,7 +50,95 @@
 static const gchar *brightness_glsl_declarations =
-"uniform float brightness;                                                 \n";
+"uniform float brightness;                                                 \n"
+"uniform float refraction_strength;                                        \n"
+"uniform vec2  u_refract_size;                                             \n"
+"uniform float u_refract_radius;                                           \n"
+"/* Shared outputs for brightness pass lighting */                         \n"
+"float r_transition = 0.0;                                                 \n"
+"float r_border = 0.0;                                                     \n"
+"float r_gradient = 0.0;                                                   \n";
 
 static const gchar *brightness_glsl =
-"  cogl_color_out.rgb *= brightness;                                       \n";
+"  cogl_color_out.rgb *= brightness;                                       \n"
+"  /* Border highlight from SDF */                                         \n"
+"  cogl_color_out.rgb += vec3(r_border * r_transition * 0.15);             \n"
+"  /* Vertical gradient for top-light gloss */                             \n"
+"  cogl_color_out.rgb += vec3(r_gradient * r_transition * 0.2);            \n";
+
+static const gchar *refraction_pre_glsl =
+"/* Box-lens refraction adapted from shadersample.txt.                     \n"
+" * Uses SDF-based sin() warp for zoom-lens refraction.                    \n"
+" * refraction_strength controls lens warp amount (0 = off). */            \n"
+"                                                                          \n"
+"/* Aspect-corrected UV space */                                           \n"
+"vec2 r_ar = vec2(u_refract_size.x / u_refract_size.y, 1.0);              \n"
+"vec2 r_m2 = cogl_tex_coord.st - 0.5;                                     \n"
+"vec2 r_pos = vec2(r_m2.x * r_ar.x, r_m2.y);                              \n"
+"                                                                          \n"
+"/* Rounded-rect box SDF (Iquilez) with per-corner radii */                \n"
+"vec2 r_wh = vec2(0.5, 0.5) * r_ar;                                       \n"
+"float r_cr = u_refract_radius / u_refract_size.y;                         \n"
+"vec4 r_corners = vec4(r_cr);                                              \n"
+"r_corners.xy = (r_pos.x > 0.0) ? r_corners.xy : r_corners.zw;            \n"
+"r_corners.x  = (r_pos.y > 0.0) ? r_corners.x  : r_corners.y;            \n"
+"vec2 r_q = abs(r_pos) - r_wh + r_corners.x;                              \n"
+"float r_sd = min(max(r_q.x, r_q.y), 0.0)                                 \n"
+"           + length(max(r_q, vec2(0.0))) - r_corners.x;                  \n"
+"                                                                          \n"
+"/* Anti-aliased transition using screen-space derivatives */              \n"
+"float r_aa = max(fwidth(r_sd), 0.75 / u_refract_size.y);                  \n"
+"r_transition = smoothstep(r_aa, -r_aa, r_sd);                             \n"
+"                                                                          \n"
+"/* Border highlight: 1 pixel wide stroke */                               \n"
+"float r_bw = 0.5 / u_refract_size.y;                                      \n"
+"r_border = smoothstep(r_aa, 0.0, abs(r_sd + r_bw) - r_bw);                \n"
+"                                                                          \n"
+"/* Gradient ring for top-light gloss (4px band) */                        \n"
+"float r_gw = 2.0 / u_refract_size.y;                                      \n"
+"float r_grad_ring = smoothstep(2.0*r_aa, -2.0*r_aa, r_sd + r_gw)          \n"
+"                  - smoothstep(1.0*r_aa, -1.0*r_aa, r_sd - r_gw);        \n"
+"r_gradient = clamp(clamp(r_m2.y, 0.0, 0.2) + 0.1, 0.0, 1.0) / 2.0       \n"
+"           + clamp(clamp(-r_m2.y, -1.0, 0.2) * r_grad_ring              \n"
+"                   + 0.1, 0.0, 1.0) / 2.0;                              \n"
+"                                                                          \n"
+"/* Zoom-lens refraction: sin(pow(dist, 0.25) * pi/2) warp */             \n"
+"if (r_transition > 0.0 && refraction_strength > 0.0) {                    \n"
+"  float r_dist = clamp(-r_sd / refraction_strength, 0.0, 1.0);           \n"
+"  vec2 r_lens = (cogl_tex_coord.st - 0.5)                                \n"
+"              * sin(pow(r_dist, 0.25) * 1.5707963) + 0.5;                \n"
+"  cogl_tex_coord.st = mix(cogl_tex_coord.st, r_lens, r_transition);      \n"
+"}                                                                         \n";
 
 static const gchar *mask_glsl_declarations =
@@ -96,6 +184,10 @@
   int corner_radius_uniform;
   int mask_size_uniform;
 
+  int refract_size_uniform;
+  int refract_radius_uniform;
+  int refraction_strength_uniform;
+
   ShellBlurMode mode;
   float downscale_factor;
   float brightness;
@@ -103,6 +195,7 @@
 
   float corner_radius;
+  float refraction_strength;
 };
 
@@ -115,6 +208,7 @@
   PROP_MODE,
   PROP_CORNER_RADIUS,
+  PROP_REFRACTION_STRENGTH,
   N_PROPS
 };
 
@@ -171,6 +265,14 @@
   return cogl_pipeline_copy (brightness_pipeline);
 }
 
+  if (G_UNLIKELY (brightness_pipeline == NULL))
+    {
+      /* After existing brightness snippet, add refraction texture-lookup snippet */
+      snippet = cogl_snippet_new (COGL_SNIPPET_HOOK_TEXTURE_LOOKUP,
+                                  NULL, NULL);
+      cogl_snippet_set_pre (snippet, refraction_pre_glsl);
+      cogl_pipeline_add_layer_snippet (brightness_pipeline, 0, snippet);
+      g_object_unref (snippet);
+    }
 
@@ -209,6 +311,27 @@
     }
 }
 
+  if (self->refraction_strength_uniform > -1)
+    cogl_pipeline_set_uniform_1f (self->brightness_fb.pipeline,
+                                  self->refraction_strength_uniform,
+                                  self->refraction_strength);
+
+  if (self->refract_size_uniform > -1)
+    {
+      float width, height;
+      clutter_actor_get_size (self->actor, &width, &height);
+      const float size[2] = { width, height };
+      cogl_pipeline_set_uniform_float (self->brightness_fb.pipeline,
+                                       self->refract_size_uniform,
+                                       2, 1, size);
+    }
+
+  if (self->refract_radius_uniform > -1)
+    cogl_pipeline_set_uniform_1f (self->brightness_fb.pipeline,
+                                  self->refract_radius_uniform,
+                                  self->corner_radius);
+
 static void
 setup_projection_matrix (CoglFramebuffer *framebuffer,
@@ -833,6 +956,10 @@
     case PROP_CORNER_RADIUS:
       g_value_set_float (value, self->corner_radius);
       break;
+
+    case PROP_REFRACTION_STRENGTH:
+      g_value_set_float (value, self->refraction_strength);
+      break;
 
     default:
@@ -864,6 +991,10 @@
     case PROP_CORNER_RADIUS:
       shell_blur_effect_set_corner_radius (self, g_value_get_float (value));
       break;
+
+    case PROP_REFRACTION_STRENGTH:
+      shell_blur_effect_set_refraction_strength (self, g_value_get_float (value));
+      break;
 
     default:
@@ -905,6 +1036,11 @@
   properties[PROP_CORNER_RADIUS] =
     g_param_spec_float ("corner-radius", NULL, NULL,
                         0.f, G_MAXFLOAT, 0.f,
                         G_PARAM_READWRITE | G_PARAM_STATIC_STRINGS | G_PARAM_EXPLICIT_NOTIFY);
 
+  properties[PROP_REFRACTION_STRENGTH] =
+    g_param_spec_float ("refraction-strength", NULL, NULL,
+                        0.f, 2.f, 0.f,
+                        G_PARAM_READWRITE | G_PARAM_STATIC_STRINGS | G_PARAM_EXPLICIT_NOTIFY);
+
   g_object_class_install_properties (object_class, N_PROPS, properties);
 }
 
@@ -919,12 +1055,22 @@
   self->corner_radius = 0.f;
+  self->refraction_strength = 0.f;
 
   self->actor_fb.pipeline = create_base_pipeline ();
   self->background_fb.pipeline = create_base_pipeline ();
   self->brightness_fb.pipeline = create_brightness_pipeline ();
   self->mask_fb.pipeline = create_mask_pipeline ();
   self->brightness_uniform =
     cogl_pipeline_get_uniform_location (self->brightness_fb.pipeline, "brightness");
+  self->refraction_strength_uniform =
+    cogl_pipeline_get_uniform_location (self->brightness_fb.pipeline, "refraction_strength");
+  self->refract_size_uniform =
+    cogl_pipeline_get_uniform_location (self->brightness_fb.pipeline, "u_refract_size");
+  self->refract_radius_uniform =
+    cogl_pipeline_get_uniform_location (self->brightness_fb.pipeline, "u_refract_radius");
   self->corner_radius_uniform =
@@ -1028,3 +1174,28 @@
   g_object_notify_by_pspec (G_OBJECT (self), properties[PROP_CORNER_RADIUS]);
 }
+
+float
+shell_blur_effect_get_refraction_strength (ShellBlurEffect *self)
+{
+  g_return_val_if_fail (SHELL_IS_BLUR_EFFECT (self), 0.f);
+  return self->refraction_strength;
+}
+
+void
+shell_blur_effect_set_refraction_strength (ShellBlurEffect *self,
+                                           float            refraction_strength)
+{
+  g_return_if_fail (SHELL_IS_BLUR_EFFECT (self));
+
+  if (self->refraction_strength == refraction_strength)
+    return;
+
+  self->refraction_strength = CLAMP (refraction_strength, 0.f, 2.f);
+  self->cache_flags &= ~BLUR_APPLIED;
+
+  if (self->actor)
+    clutter_effect_queue_repaint (CLUTTER_EFFECT (self));
+
+  g_object_notify_by_pspec (G_OBJECT (self), properties[PROP_REFRACTION_STRENGTH]);
+}
diff --git a/src/shell-blur-effect.h b/src/shell-blur-effect.h
--- a/src/shell-blur-effect.h
+++ b/src/shell-blur-effect.h
@@ -58,4 +58,8 @@
 void shell_blur_effect_set_corner_radius (ShellBlurEffect *self,
                                           float            corner_radius);
 
+float shell_blur_effect_get_refraction_strength (ShellBlurEffect *self);
+void shell_blur_effect_set_refraction_strength (ShellBlurEffect *self,
+                                                float            refraction_strength);
+
 G_END_DECLS
