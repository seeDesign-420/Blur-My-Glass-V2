+    "\n"
+    " * Uses SDF-based sin() warp for zoom-lens refraction.                    "
+    "\n"
+    " * refraction_strength controls lens warp amount (0 = off). */            "
+    "\n"
+    "                                                                          "
+    "\n"
+    "/* Aspect-corrected UV space */                                           "
+    "\n"
+    "vec2 r_ar = vec2(u_refract_size.x / u_refract_size.y, 1.0);              "
+    "\n"
+    "vec2 r_m2 = cogl_tex_coord.st - 0.5;                                     "
+    "\n"
+    "vec2 r_pos = vec2(r_m2.x * r_ar.x, r_m2.y);                              "
+    "\n"
+    "                                                                          "
+    "\n"
+    "/* Rounded-rect box SDF (Iquilez) with per-corner radii */                "
+    "\n"
+    "vec2 r_wh = vec2(0.5, 0.5) * r_ar;                                       "
+    "\n"
+    "float r_cr = u_refract_radius / u_refract_size.y;                         "
+    "\n"
+    "vec4 r_corners = vec4(r_cr);                                              "
+    "\n"
