+    "\n"
+    "r_corners.x  = (r_pos.y > 0.0) ? r_corners.x  : r_corners.y;            "
+    "\n"
+    "vec2 r_q = abs(r_pos) - r_wh + r_corners.x;                              "
+    "\n"
