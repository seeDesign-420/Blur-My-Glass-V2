+    "\n"
+    "                                                                          "
+    "\n"
+    "/* Zoom-lens refraction: sin(pow(dist, 0.25) * pi/2) warp */             "
+    "\n"
+    "if (r_transition > 0.0 && refraction_strength > 0.0) {                    "
+    "\n"
