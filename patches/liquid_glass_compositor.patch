 static const gchar *brightness_glsl_declarations =
-"uniform float brightness;                                                 \n";
+"uniform float brightness;                                                 \n"
+"uniform float vibrancy;                                                   \n";
 
 static const gchar *brightness_glsl =
-"  cogl_color_out.rgb *= brightness;                                       \n";
+"  float r_shape = mix(1.0, r_transition, step(0.0001, r_strength));      \n"
+"  cogl_color_out.rgb *= brightness * r_shape;                            \n"
+"  cogl_color_out.a *= r_shape;                                           \n"
+"  float v_amount = clamp(vibrancy, 0.0, 1.0);                            \n"
+"  vec3 v_gray = vec3(dot(cogl_color_out.rgb, vec3(0.299, 0.587, 0.114)));\n"
+"  float v_luma = v_gray.r;                                               \n"
+"  float v_midtones = 1.0 - abs(v_luma * 2.0 - 1.0);                     \n"
+"  float v_saturation = 1.0 + (0.35 + 0.55 * v_midtones) * v_amount;      \n"
+"  vec3 v_vibrant = v_gray + (cogl_color_out.rgb - v_gray) * v_saturation;\n"
+"  float v_lift = (0.03 + 0.10 * v_midtones) * v_amount;                  \n"
+"  float r_material = max(v_amount * 0.8, clamp(r_strength * 0.55, 0.0, 1.0));\n"
+"  cogl_color_out.rgb = clamp(mix(v_vibrant, vec3(1.0), v_lift), 0.0, 1.0);\n"
+"  /* Border highlight from SDF */                                         \n"
+"  cogl_color_out.rgb += vec3(r_border * r_transition * r_material * 0.12);\n"
+"  /* Vertical gradient for top-light gloss */                             \n"
+"  cogl_color_out.rgb += vec3(r_gradient * r_transition * r_material * 0.14);\n";
+
+/* Declarations for the texture-lookup (layer) snippet.
+ * Uniforms MUST be declared here because COGL_SNIPPET_HOOK_TEXTURE_LOOKUP
+ * layer snippet code is assembled before fragment-hook declarations in the
+ * generated GLSL.  All declarations go into global scope, so the shared
+ * r_* globals written here are readable by the fragment hook above. */
+static const gchar *refraction_lookup_declarations =
+"uniform float refraction_strength;                                        \n"
+"uniform vec2  u_refract_size;                                             \n"
+"uniform vec2  u_refract_origin;                                           \n"
+"uniform vec2  u_refract_bounds;                                           \n"
+"uniform float u_refract_radius;                                           \n"
+"uniform float u_refract_inner_radius;                                     \n"
+"/* Shared globals: written by texture-lookup, read by fragment hook */    \n"
+"float r_transition = 0.0;                                                 \n"
+"float r_border = 0.0;                                                     \n"
+"float r_gradient = 0.0;                                                   \n"
+"float r_strength = 0.0;                                                   \n";
+
+static const gchar *refraction_replace_glsl =
+"/* Box-lens refraction with anti-aliased texture sampling.                 \n"
+" * Uses SDF-based sin() warp for zoom-lens refraction.                    \n"
+" * Uses bounds-safe multi-sample texture2D lookups for broad compatibility.*/\n"
+"                                                                          \n"
+"r_strength = clamp(refraction_strength, 0.0, 2.0);                       \n"
+"                                                                          \n"
+"/* Actor clips can be smaller than the blur actor (static window blur). */\n"
+"vec2 r_actor_size = max(u_refract_size, vec2(1.0));                      \n"
+"vec2 r_bounds = max(u_refract_bounds, vec2(1.0));                        \n"
+"vec2 r_local_uv = (cogl_tex_coord.st * r_actor_size - u_refract_origin) / r_bounds;\n"
+"/* Aspect-corrected UV space */                                           \n"
+"vec2 r_ar = vec2(r_bounds.x / r_bounds.y, 1.0);                          \n"
+"vec2 r_m2 = r_local_uv - 0.5;                                            \n"
+"vec2 r_pos = vec2(r_m2.x * r_ar.x, r_m2.y);                              \n"
+"                                                                          \n"
+"/* Rounded-rect box SDF (Iquilez) with per-corner radii */                \n"
+"vec2 r_wh = vec2(0.5, 0.5) * r_ar;                                       \n"
+"float r_cr = u_refract_radius / r_bounds.y;                               \n"
+"vec4 r_corners = vec4(r_cr);                                              \n"
+"r_corners.xy = (r_pos.x > 0.0) ? r_corners.xy : r_corners.zw;            \n"
+"r_corners.x  = (r_pos.y > 0.0) ? r_corners.x  : r_corners.y;            \n"
+"vec2 r_q = abs(r_pos) - r_wh + r_corners.x;                              \n"
+"float r_sd = min(max(r_q.x, r_q.y), 0.0)                                 \n"
+"           + length(max(r_q, vec2(0.0))) - r_corners.x;                  \n"
+"float r_inner_cr = u_refract_inner_radius / r_bounds.y;                   \n"
+"vec2 r_inner_q = abs(r_pos) - r_wh + r_inner_cr;                          \n"
+"float r_inner_sd = min(max(r_inner_q.x, r_inner_q.y), 0.0)                \n"
+"                 + length(max(r_inner_q, vec2(0.0))) - r_inner_cr;        \n"
+"                                                                          \n"
+"/* Anti-aliased transition using screen-space derivatives */              \n"
+"float r_aa = max(fwidth(r_sd), 0.75 / r_bounds.y);                        \n"
+"r_transition = smoothstep(r_aa, -r_aa, r_sd);                             \n"
+"                                                                          \n"
+"/* Border highlight: 1 pixel wide stroke */                               \n"
+"float r_bw = 0.5 / r_bounds.y;                                            \n"
+"r_border = smoothstep(r_aa, 0.0, abs(r_sd + r_bw) - r_bw);                \n"
+"                                                                          \n"
+"/* Gradient ring for top-light gloss (4px band) */                        \n"
+"float r_gw = 2.0 / r_bounds.y;                                            \n"
+"float r_grad_ring = smoothstep(2.0*r_aa, -2.0*r_aa, r_sd + r_gw)          \n"
+"                  - smoothstep(1.0*r_aa, -1.0*r_aa, r_sd - r_gw);        \n"
+"float r_vertical = 1.0 - clamp(r_local_uv.y, 0.0, 1.0);                  \n"
+"r_gradient = r_grad_ring * (0.25 + 0.75 * r_vertical);                   \n"
+"                                                                          \n"
+"/* Zoom-lens refraction: sin(pow(dist, 0.25) * pi/2) warp */             \n"
+"vec2 r_final_uv = cogl_tex_coord.st;                                      \n"
+"if (r_strength > 0.0 && r_transition > 0.0) {                            \n"
+"  float r_dist = clamp(-r_inner_sd / r_strength, 0.0, 1.0);              \n"
+"  float r_warp = sin(pow(r_dist, 0.25) * 1.5707963);                     \n"
+"  vec2 r_lens_local = r_m2 * r_warp + 0.5;                               \n"
+"  vec2 r_lens = (u_refract_origin + r_lens_local * r_bounds) / r_actor_size;\n"
+"  r_final_uv = mix(cogl_tex_coord.st, r_lens, r_transition);             \n"
+"}                                                                         \n"
+"                                                                          \n"
+"/* Bounds-safe RGSS sampling to soften aliasing without textureGrad. */   \n"
+"vec2 r_margin = vec2(1.25) / r_actor_size;                                \n"
+"r_final_uv = clamp(r_final_uv, r_margin, vec2(1.0) - r_margin);           \n"
+"vec2 r_texel = vec2(0.75) / r_actor_size;                                  \n"
+"vec2 r_off1 = vec2( 0.375, -0.125) * r_texel;                             \n"
+"vec2 r_off2 = vec2( 0.125,  0.375) * r_texel;                             \n"
+"vec2 r_off3 = vec2(-0.375,  0.125) * r_texel;                             \n"
+"vec2 r_off4 = vec2(-0.125, -0.375) * r_texel;                             \n"
+"vec2 r_uv1 = clamp(r_final_uv + r_off1, r_margin, vec2(1.0) - r_margin);  \n"
+"vec2 r_uv2 = clamp(r_final_uv + r_off2, r_margin, vec2(1.0) - r_margin);  \n"
+"vec2 r_uv3 = clamp(r_final_uv + r_off3, r_margin, vec2(1.0) - r_margin);  \n"
+"vec2 r_uv4 = clamp(r_final_uv + r_off4, r_margin, vec2(1.0) - r_margin);  \n"
+"cogl_texel = 0.25 * (                                                     \n"
+"  texture2D(cogl_sampler, r_uv1) +                                        \n"
+"  texture2D(cogl_sampler, r_uv2) +                                        \n"
+"  texture2D(cogl_sampler, r_uv3) +                                        \n"
+"  texture2D(cogl_sampler, r_uv4));                                        \n";
 
