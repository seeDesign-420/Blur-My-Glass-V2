+
+float
+shell_blur_effect_get_refraction_strength (ShellBlurEffect *self)
+{
+  g_return_val_if_fail (SHELL_IS_BLUR_EFFECT (self), 0.f);
+  return self->refraction_strength;
+}
+
+void
+shell_blur_effect_set_refraction_strength (ShellBlurEffect *self,
+                                           float            refraction_strength)
+{
+  g_return_if_fail (SHELL_IS_BLUR_EFFECT (self));
+
+  refraction_strength = CLAMP (refraction_strength, 0.f, 2.f);
+
+  if (self->refraction_strength == refraction_strength)
+    return;
+
+  self->refraction_strength = refraction_strength;
+  self->cache_flags &= ~BLUR_APPLIED;
+
+  if (self->actor)
+    clutter_effect_queue_repaint (CLUTTER_EFFECT (self));
+
+  g_object_notify_by_pspec (G_OBJECT (self), properties[PROP_REFRACTION_STRENGTH]);
+}
+
+float
+shell_blur_effect_get_refraction_radius (ShellBlurEffect *self)
+{
+  g_return_val_if_fail (SHELL_IS_BLUR_EFFECT (self), 0.f);
+  return self->refraction_radius;
+}
+
+void
+shell_blur_effect_set_refraction_radius (ShellBlurEffect *self,
+                                         float            refraction_radius)
+{
+  g_return_if_fail (SHELL_IS_BLUR_EFFECT (self));
+
+  refraction_radius = MAX (0.f, refraction_radius);
+
+  if (self->refraction_radius == refraction_radius)
+    return;
+
+  self->refraction_radius = refraction_radius;
+  self->cache_flags &= ~BLUR_APPLIED;
+
+  if (self->actor)
+    clutter_effect_queue_repaint (CLUTTER_EFFECT (self));
+
+  g_object_notify_by_pspec (G_OBJECT (self), properties[PROP_REFRACTION_RADIUS]);
+}
+
+float
+shell_blur_effect_get_refraction_inner_radius (ShellBlurEffect *self)
+{
+  g_return_val_if_fail (SHELL_IS_BLUR_EFFECT (self), 0.f);
+  return self->refraction_inner_radius;
+}
+
+void
+shell_blur_effect_set_refraction_inner_radius (ShellBlurEffect *self,
+                                               float            refraction_inner_radius)
+{
+  g_return_if_fail (SHELL_IS_BLUR_EFFECT (self));
+
+  refraction_inner_radius = MAX (0.f, refraction_inner_radius);
+
+  if (self->refraction_inner_radius == refraction_inner_radius)
+    return;
+
+  self->refraction_inner_radius = refraction_inner_radius;
+  self->cache_flags &= ~BLUR_APPLIED;
+
+  if (self->actor)
+    clutter_effect_queue_repaint (CLUTTER_EFFECT (self));
+
+  g_object_notify_by_pspec (G_OBJECT (self), properties[PROP_REFRACTION_INNER_RADIUS]);
+}
